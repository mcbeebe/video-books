{
  "name": "video-books",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "WCAP render pipeline — produces long-form videos from chapter specs.",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
